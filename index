        }

        function saveStorageData() {
            try {
                localStorage.setItem('weldmaster_profiles', JSON.stringify(profiles));
                localStorage.setItem('weldmaster_projects', JSON.stringify(projects));
            } catch(e) {
                console.warn("Save failed", e);
            }
        }

        function populateProfileDropdown() {
