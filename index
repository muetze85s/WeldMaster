<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WeldMaster FCAW Assistent PRO</title>
    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#d97706">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #d97706;
            --bg-warm: #fdfaf7;
            --card-bg: #ffffff;
            --text-main: #451a03;
        }
        body {
            background-color: var(--bg-warm);
            color: var(--text-main);
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }
        .chart-container {
            position: relative;
            width: 100%;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            height: 220px;
        }
        .custom-shadow {
            box-shadow: 0 10px 25px -5px rgba(217, 119, 6, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="min-h-screen pb-12">

    <header class="bg-gradient-to-r from-amber-700 to-amber-900 text-white py-5 shadow-lg mb-6">
        <div class="container mx-auto px-4 flex justify-between items-center">
            <div>
                <h1 class="text-2xl font-black flex items-center tracking-wide">
                    <span class="mr-2 text-2xl">🔥</span> WELDMASTER FCAW
                </h1>
                <p class="text-amber-200 text-xs mt-0.5 font-medium">Fülldraht-Assistent, Profilspeicher & KI-Analyse</p>
            </div>
            <div class="flex items-center space-x-2">
                <button id="pwa-install-btn" class="hidden bg-amber-500 hover:bg-amber-400 text-amber-950 font-black text-xs px-3 py-1.5 rounded-lg shadow transition">
                    📲 App Installieren
                </button>
                <span class="bg-amber-600/50 text-amber-100 text-xs px-2.5 py-1 rounded-full border border-amber-400/30 font-mono">v3.0 PWA</span>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 max-w-4xl">
        
        <!-- Navigation Bar -->
        <nav class="flex overflow-x-auto space-x-2 mb-6 pb-2 scrollbar-hide border-b border-amber-200/60">
            <button onclick="showSection('profile')" id="nav-profile" class="nav-btn px-4 py-2.5 rounded-xl font-bold text-xs uppercase tracking-wider transition-all bg-amber-600 text-white shadow-md">
                1. Geräte-Profil
            </button>
            <button onclick="showSection('project')" id="nav-project" class="nav-btn px-4 py-2.5 rounded-xl font-bold text-xs uppercase tracking-wider transition-all bg-white text-gray-600 hover:bg-amber-50">
                2. Projekt-Setup
            </button>
            <button onclick="showSection('dashboard')" id="nav-dashboard" class="nav-btn px-4 py-2.5 rounded-xl font-bold text-xs uppercase tracking-wider transition-all bg-white text-gray-600 hover:bg-amber-50">
                3. Parameter & Führung
            </button>
            <button onclick="showSection('inspection')" id="nav-inspection" class="nav-btn px-4 py-2.5 rounded-xl font-bold text-xs uppercase tracking-wider transition-all bg-white text-gray-600 hover:bg-amber-50">
                4. KI-Nahtkontrolle
            </button>
        </nav>

        <!-- SECTION 1: GERÄTE-PROFIL -->
        <section id="profile" class="step-section space-y-6">
            <div class="bg-white rounded-2xl p-6 custom-shadow border border-amber-100">
                
                <!-- Profile Management Bar -->
                <div class="bg-amber-50/80 p-4 rounded-xl border border-amber-200 mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                    <div class="w-full sm:w-auto flex-1">
                        <label class="block text-[10px] font-black uppercase tracking-wider text-amber-900 mb-1">Gespeichertes Geräte-Profil laden</label>
                        <select id="profile_select" onchange="loadSelectedProfile()" class="w-full border rounded-lg p-2 font-bold text-xs text-gray-800 bg-white outline-none focus:ring-2 focus:ring-amber-500">
                            <!-- Populated dynamically -->
                        </select>
                    </div>
                    <div class="flex space-x-2 w-full sm:w-auto justify-end">
                        <button onclick="saveCurrentProfile()" class="bg-amber-600 hover:bg-amber-700 text-white text-xs px-3.5 py-2 rounded-lg font-bold shadow transition">
                            💾 Profil Speichern
                        </button>
                        <button onclick="createNewProfile()" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs px-3.5 py-2 rounded-lg font-bold border border-gray-300 transition">
                            ➕ Neu
                        </button>
                        <button onclick="deleteCurrentProfile()" class="bg-red-50 hover:bg-red-100 text-red-700 text-xs px-2.5 py-2 rounded-lg font-bold border border-red-200 transition" title="Profil löschen">
                            🗑️
                        </button>
                    </div>
                </div>

                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-xl font-bold text-amber-900 flex items-center">
                        <span class="w-8 h-8 bg-amber-600 text-white rounded-lg flex items-center justify-center mr-3 text-sm font-black">1</span>
                        Geräte-Spezifikationen
                    </h2>
                </div>
                
                <div class="mb-4">
                    <label class="block text-xs font-bold uppercase text-amber-900 mb-1">Bezeichnung des Schweißgeräts</label>
                    <input type="text" id="profile_name" value="Mein Fülldraht-Gerät" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none" onchange="updateUI()">
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                    <div class="bg-amber-50/50 p-4 rounded-xl border border-amber-100">
                        <label class="block text-xs font-bold uppercase text-amber-900 mb-2">Spannungsbereich (Volt U)</label>
                        <div class="flex space-x-3">
                            <div>
                                <span class="text-[10px] text-gray-500 font-bold block">MIN VOLT</span>
                                <input type="number" step="0.1" id="u_min" value="14.0" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none" onchange="updateUI()">
                            </div>
                            <div>
                                <span class="text-[10px] text-gray-500 font-bold block">MAX VOLT</span>
                                <input type="number" step="0.1" id="u_max" value="17.4" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none" onchange="updateUI()">
                            </div>
                        </div>
                    </div>

                    <div class="bg-amber-50/50 p-4 rounded-xl border border-amber-100">
                        <label class="block text-xs font-bold uppercase text-amber-900 mb-2">Stromstärkebereich (Ampere I)</label>
                        <div class="flex space-x-3">
                            <div>
                                <span class="text-[10px] text-gray-500 font-bold block">MIN AMPERE</span>
                                <input type="number" id="i_min" value="30" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none" onchange="updateUI()">
                            </div>
                            <div>
                                <span class="text-[10px] text-gray-500 font-bold block">MAX AMPERE</span>
                                <input type="number" id="i_max" value="120" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none" onchange="updateUI()">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-4 rounded-xl border border-gray-200 mb-6">
                    <label class="block text-xs font-bold uppercase text-gray-700 mb-3">Drahtvorschub-Steuerung des Geräts</label>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <label class="flex items-center p-3 border rounded-xl cursor-pointer hover:bg-amber-50 transition border-amber-200 bg-amber-50/30">
                            <input type="radio" name="wfs_mode" value="separate" checked onchange="toggleWfsMode()" class="text-amber-600 focus:ring-amber-500">
                            <div class="ml-3">
                                <span class="block text-xs font-bold text-gray-800">Separater Drahtregler (1-10)</span>
                                <span class="block text-[11px] text-gray-500">Drahtvorschub ist unabhängig einstellbar</span>
                            </div>
                        </label>
                        <label class="flex items-center p-3 border rounded-xl cursor-pointer hover:bg-amber-50 transition border-gray-200">
                            <input type="radio" name="wfs_mode" value="synergic" onchange="toggleWfsMode()" class="text-amber-600 focus:ring-amber-500">
                            <div class="ml-3">
                                <span class="block text-xs font-bold text-gray-800">Automatisch (Synergisch)</span>
                                <span class="block text-[11px] text-gray-500">Drahtgeschwindigkeit koppelt sich stufenlos an Stromstärke</span>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Calibration Test -->
                <div id="calibration-box" class="p-5 bg-gradient-to-br from-amber-500/10 to-orange-500/10 rounded-xl border border-amber-200">
                    <h3 class="font-bold text-amber-900 text-sm mb-1 flex items-center">
                        <span class="mr-2">📏</span> Drahtvorschub-Kalibrierung (15-Sekunden-Test)
                    </h3>
                    <p class="text-xs text-amber-800 mb-4">
                        Stelle deinen Drahtregler auf <strong>Stufe 5</strong>. Halte die Pistole ohne Lichtbogen für exakt 15 Sekunden gedrückt und miss die ausgetretene Drahtlänge.
                    </p>
                    <div class="flex flex-col sm:flex-row items-end gap-3">
                        <div class="flex-1 w-full">
                            <label class="block text-[10px] font-bold text-amber-900 mb-1 uppercase">Gemessene Länge (cm in 15s)</label>
                            <input type="number" id="cal_length" value="150" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none bg-white">
                        </div>
                        <button onclick="calculateWFSConstant()" class="w-full sm:w-auto bg-amber-600 text-white px-6 py-2.5 rounded-lg font-bold text-sm hover:bg-amber-700 transition shadow">
                            Jetzt Kalibrieren
                        </button>
                    </div>
                    <div id="cal_result" class="mt-3 p-2 bg-amber-100 rounded-lg text-xs font-bold text-amber-900 flex items-center justify-between">
                        <span>Ergebnis für Stufe 5: <span id="v_wfs_val" class="text-amber-700 font-mono text-sm">6.0</span> m/min</span>
                        <span class="text-[10px] text-amber-700 font-mono">Skalierung aktualisiert</span>
                    </div>
                </div>

                <div class="mt-6 flex justify-end">
                    <button onclick="showSection('project')" class="bg-amber-600 text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-amber-700 transition flex items-center shadow-lg">
                        Weiter zu Projekt-Setup →
                    </button>
                </div>
            </div>
        </section>

        <!-- SECTION 2: PROJEKT-SETUP -->
        <section id="project" class="step-section hidden space-y-6">
            <div class="bg-white rounded-2xl p-6 custom-shadow border border-amber-100">
                
                <!-- Project Management Bar -->
                <div class="bg-amber-50/80 p-4 rounded-xl border border-amber-200 mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                    <div class="w-full sm:w-auto flex-1">
                        <label class="block text-[10px] font-black uppercase tracking-wider text-amber-900 mb-1">Gespeichertes Projekt laden</label>
                        <select id="project_select" onchange="loadSelectedProject()" class="w-full border rounded-lg p-2 font-bold text-xs text-gray-800 bg-white outline-none focus:ring-2 focus:ring-amber-500">
                            <!-- Populated dynamically -->
                        </select>
                    </div>
                    <div class="flex space-x-2 w-full sm:w-auto justify-end">
                        <button onclick="saveCurrentProject()" class="bg-amber-600 hover:bg-amber-700 text-white text-xs px-3.5 py-2 rounded-lg font-bold shadow transition">
                            💾 Projekt Speichern
                        </button>
                        <button onclick="createNewProject()" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs px-3.5 py-2 rounded-lg font-bold border border-gray-300 transition">
                            ➕ Neues Projekt
                        </button>
                    </div>
                </div>

                <h2 class="text-xl font-bold text-amber-900 mb-4 flex items-center">
                    <span class="w-8 h-8 bg-amber-600 text-white rounded-lg flex items-center justify-center mr-3 text-sm font-black">2</span>
                    Projekt-Spezifikationen
                </h2>

                <div class="mb-6">
                    <label class="block text-xs font-bold uppercase text-amber-900 mb-1">Projektbezeichnung</label>
                    <input type="text" id="project_name" value="Neues Schweißprojekt" class="w-full border rounded-lg p-2.5 font-bold text-gray-800 focus:ring-2 focus:ring-amber-500 outline-none" onchange="updateUI()">
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- Material & Thickness selection -->
                    <div class="space-y-6">
                        <!-- Dual Material Input for Dissimilar Joining -->
                        <div>
                            <label class="block font-bold text-xs uppercase text-amber-900 tracking-wider mb-2">1. Werkstoffe der Fügepartner</label>
                            
                            <div class="space-y-3">
                                <div>
                                    <span class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Teil 1 (Hauptwerkstoff)</span>
                                    <select id="mat1" class="w-full border-2 border-gray-200 rounded-xl p-2.5 text-xs font-bold text-gray-800 outline-none focus:border-amber-500 bg-white" onchange="updateUI()">
                                        <option value="steel">Unlegierter Rohstahl (S235 / S355)</option>
                                        <option value="galvanized">Verzinkter Stahl (Feuer-/Sendzimirverzinkt)</option>
                                        <option value="stainless">Edelstahl / Rostfrei (V2A / V4A)</option>
                                    </select>
                                </div>

                                <div>
                                    <span class="text-[10px] font-bold text-gray-500 uppercase block mb-1">Teil 2 (Zweiter Fügepartner)</span>
                                    <select id="mat2" class="w-full border-2 border-gray-200 rounded-xl p-2.5 text-xs font-bold text-gray-800 outline-none focus:border-amber-500 bg-white" onchange="updateUI()">
                                        <option value="same">Gleicher Werkstoff wie Teil 1</option>
                                        <option value="steel">Unlegierter Rohstahl (S235 / S355)</option>
                                        <option value="galvanized">Verzinkter Stahl (Feuer-/Sendzimirverzinkt)</option>
                                        <option value="stainless">Edelstahl / Rostfrei (V2A / V4A)</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Mixed Thickness Input (0.1mm steps with synchronized number input) -->
                        <div>
                            <label class="block font-bold text-xs uppercase text-amber-900 tracking-wider mb-2">2. Materialstärken (in 0,1 mm)</label>
                            
                            <div class="space-y-4 bg-amber-50/50 p-4 rounded-xl border border-amber-100">
                                <div>
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="text-xs font-bold text-gray-700">Stärke Teil 1:</span>
                                        <div class="flex items-center space-x-1">
                                            <input type="number" id="thickness1_num" min="0.5" max="12.0" step="0.1" value="3.0" class="w-20 text-right border rounded p-1 font-mono font-bold text-xs text-amber-900" oninput="syncThickness('num1')">
                                            <span class="text-xs font-bold text-gray-500">mm</span>
                                        </div>
                                    </div>
                                    <input type="range" id="thickness1_range" min="0.5" max="12.0" step="0.1" value="3.0" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-amber-600" oninput="syncThickness('range1')">
                                </div>

                                <div class="border-t border-amber-200/60 pt-3">
                                    <div class="flex justify-between items-center mb-1">
                                        <span class="text-xs font-bold text-gray-700">Stärke Teil 2 (optional abweichend):</span>
                                        <div class="flex items-center space-x-1">
                                            <input type="number" id="thickness2_num" min="0.5" max="12.0" step="0.1" value="3.0" class="w-20 text-right border rounded p-1 font-mono font-bold text-xs text-amber-900" oninput="syncThickness('num2')">
                                            <span class="text-xs font-bold text-gray-500">mm</span>
                                        </div>
                                    </div>
                                    <input type="range" id="thickness2_range" min="0.5" max="12.0" step="0.1" value="3.0" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-amber-600" oninput="syncThickness('range2')">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Position & Wire Gas -->
                    <div class="space-y-6">
                        <div>
                            <label class="block font-bold text-xs uppercase text-amber-900 tracking-wider mb-2">3. Schweißposition</label>
                            <select id="position" class="w-full border-2 border-gray-200 rounded-xl p-3 text-xs font-bold text-gray-800 outline-none focus:border-amber-500 bg-white" onchange="updateUI()">
                                <option value="horizontal">Horizontal / Wanne (PA/PB) - Einsteigerfreundlich</option>
                                <option value="vertical_up">Steignaht (PF) - Senkrecht nach oben</option>
                                <option value="vertical_down">Fallnaht (PG) - Senkrecht nach unten (Dünnblech)</option>
                            </select>
                        </div>

                        <div>
                            <label class="block font-bold text-xs uppercase text-amber-900 tracking-wider mb-2">4. Fülldraht-Typ & Gas</label>
                            <select id="gas" class="w-full border-2 border-gray-200 rounded-xl p-3 text-xs font-bold text-gray-800 outline-none focus:border-amber-500 bg-white" onchange="updateUI()">
                                <option value="none">Selbstschützend (FCAW-S / Ohne Schutzgas)</option>
                                <option value="mix">Gasgeschützt (FCAW-G mit Ar/CO2 Mix 82/18)</option>
                                <option value="co2">Gasgeschützt (100% CO2)</option>
                            </select>
                        </div>

                        <div class="p-4 bg-amber-50 rounded-xl border border-amber-200/80">
                            <h4 class="text-xs font-bold text-amber-900 mb-1 flex items-center">
                                💡 Polarisierung
                            </h4>
                            <p id="polarization_hint" class="text-[11px] text-amber-800 leading-relaxed">
                                Selbstschützender Fülldraht erfordert <strong>DCEN (Brenner an Minuspol -)</strong>.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="mt-8 flex justify-between">
                    <button onclick="showSection('profile')" class="bg-gray-100 text-gray-600 px-6 py-3 rounded-xl font-bold text-sm hover:bg-gray-200 transition">
                        ← Zurück
                    </button>
                    <button onclick="showSection('dashboard')" class="bg-amber-600 text-white px-6 py-3 rounded-xl font-bold text-sm hover:bg-amber-700 transition shadow-lg">
                        Parameter berechnen →
                    </button>
                </div>
            </div>
        </section>

        <!-- SECTION 3: PARAMETER & FÜHRUNG -->
        <section id="dashboard" class="step-section hidden space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                
                <!-- Calculated Parameters -->
                <div class="lg:col-span-2 space-y-6">
                    
                    <!-- Alert Banner for Machine Boundary Limit Exceeded -->
                    <div id="device_limit_warning" class="hidden bg-gradient-to-r from-red-500 to-amber-600 text-white p-4 rounded-2xl shadow-md border border-red-400">
                        <div class="flex items-start">
                            <span class="text-2xl mr-3">⚠️</span>
                            <div>
                                <h4 class="font-black text-sm uppercase tracking-wide">Leistungsgrenze deines Geräts erreicht!</h4>
                                <p id="device_limit_msg" class="text-xs mt-1 text-red-50 leading-relaxed">
                                    Das gewählte Material erfordert höhere Parameter als dein Gerät liefern kann. Die Werte wurden auf das Maximum deines Geräts angepasst.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-white rounded-2xl p-6 custom-shadow border-t-4 border-amber-600">
                        <div class="flex justify-between items-center mb-6">
                            <h3 class="text-lg font-black text-gray-900">Geräte-Einstellungen für dein Gerät</h3>
                            <span id="target_status_badge" class="text-xs font-bold bg-amber-100 text-amber-800 px-3 py-1 rounded-full">Optimaler Arbeitspunkt</span>
                        </div>

                        <div class="grid grid-cols-2 gap-4 mb-6">
                            <!-- Voltage output -->
                            <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100/50 rounded-2xl border border-amber-200">
                                <span class="text-[10px] font-black uppercase tracking-wider text-amber-800 block mb-1">Spannung (U)</span>
                                <div id="res_v_phys" class="text-3xl font-black text-amber-900">17.4 V</div>
                                <div id="res_v_knob" class="text-xs mt-2 font-mono font-bold bg-amber-200/80 text-amber-900 px-2.5 py-1 rounded-md inline-block">Regler Stufe: MAX (10)</div>
                            </div>

                            <!-- WFS output -->
                            <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100/50 rounded-2xl border border-amber-200">
                                <span class="text-[10px] font-black uppercase tracking-wider text-amber-800 block mb-1">Drahtvorschub (WFS)</span>
                                <div id="res_wfs_phys" class="text-3xl font-black text-amber-900">4.8 m/min</div>
                                <div id="res_wfs_knob" class="text-xs mt-2 font-mono font-bold bg-amber-200/80 text-amber-900 px-2.5 py-1 rounded-md inline-block">Automatisch gekoppelt</div>
                            </div>
                        </div>

                        <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-gray-700">Erwarteter Schweißstrom (Effektiv):</span>
                                <span id="res_amp" class="font-mono font-black text-amber-700 text-sm">114 A</span>
                            </div>
                            <div class="w-full bg-gray-200 h-3 rounded-full overflow-hidden">
                                <div id="amp_progress" class="bg-gradient-to-r from-amber-500 to-orange-600 h-full transition-all duration-500" style="width: 90%"></div>
                            </div>
                            <div class="flex justify-between text-[10px] text-gray-400 mt-1 font-bold">
                                <span>Geräte-Min: <span id="lbl_i_min">30</span>A</span>
                                <span>Auslastung</span>
                                <span>Geräte-Max: <span id="lbl_i_max">120</span>A</span>
                            </div>
                        </div>
                    </div>

                    <!-- Guidelines and Instructions -->
                    <div class="bg-white rounded-2xl p-6 custom-shadow border border-amber-100 space-y-4">
                        <h3 class="font-bold text-base text-amber-900 flex items-center">
                            <span class="mr-2">🛠️</span> Vorbereitung, Einbrand & Wärmesteuerung
                        </h3>

                        <div id="dynamic_guidelines" class="space-y-4 text-xs text-gray-700 leading-relaxed">
                            <!-- Populated via JavaScript -->
                        </div>
                    </div>
                </div>

                <!-- Torch Angle Chart & Torch Technique -->
                <div class="space-y-6">
                    <div class="bg-white rounded-2xl p-5 custom-shadow border border-amber-100 text-center">
                        <h3 class="text-xs font-bold uppercase text-gray-500 tracking-wider mb-2">Brennerhaltung & Führung</h3>
                        
                        <div class="chart-container">
                            <canvas id="torchCanvas"></canvas>
                        </div>

                        <div class="mt-2 p-3 bg-amber-50 rounded-xl border border-amber-200">
                            <p id="torch_label" class="text-xs font-bold text-amber-900">Ziehend / Schleppend (15°-20°)</p>
