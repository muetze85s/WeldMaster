        // Synchronize thickness sliders and numeric text fields
        function syncThickness(source) {
            if (source === 'range1') {
                document.getElementById('thickness1_num').value = document.getElementById('thickness1_range').value;
            } else if (source === 'num1') {
                document.getElementById('thickness1_range').value = document.getElementById('thickness1_num').value;
            } else if (source === 'range2') {
                document.getElementById('thickness2_num').value = document.getElementById('thickness2_range').value;
            } else if (source === 'num2') {
                document.getElementById('thickness2_range').value = document.getElementById('thickness2_num').value;
            }
            updateUI();
        }

        function updateUI() {
            calculateAndRenderParameters();
            updateGuidelines();
            updateTorchChart();
        }

        function calculateAndRenderParameters() {
            const u_min = parseFloat(document.getElementById('u_min').value) || 14.0;
            const u_max = parseFloat(document.getElementById('u_max').value) || 28.0;
            const i_min = parseFloat(document.getElementById('i_min').value) || 30;
            const i_max = parseFloat(document.getElementById('i_max').value) || 180;
            const wfs_mode = document.querySelector('input[name="wfs_mode"]:checked').value;

            const t1 = parseFloat(document.getElementById('thickness1_num').value) || 3.0;
            const t2 = parseFloat(document.getElementById('thickness2_num').value) || t1;
            
            // Critical thickness for heat calculation: minimum thickness prevents burn-through
            const effectiveThickness = Math.min(t1, t2) * 0.7 + Math.max(t1, t2) * 0.3;

            const mat1 = document.getElementById('mat1').value;
            const mat2 = document.getElementById('mat2').value;
            const position = document.getElementById('position').value;
            const gas = document.getElementById('gas').value;

            // Ideal current estimation for FCAW
            let amp_ideal = effectiveThickness * 38;

            if (position === 'vertical_up') amp_ideal *= 0.82;
            if (position === 'vertical_down') amp_ideal *= 1.10;

            // Ideal voltage calculation (Modified Lesnewich formula)
            let gasKorr = (gas === 'mix') ? 1.0 : (gas === 'co2' ? 1.8 : 0);
            let matKorr = (mat1 === 'stainless' || mat2 === 'stainless') ? 1.2 : 0;
            let posKorr = (position === 'vertical_up') ? -2.0 : (position === 'vertical_down' ? 0.5 : 0);

            let v_ideal = (0.045 * amp_ideal) + 13.5 + gasKorr + matKorr + posKorr;

            // STRICT DEVICE CLAMPING LOGIC
            let isLimitReached = false;
            let v_actual = v_ideal;
            let amp_actual = amp_ideal;

            if (v_actual > u_max) {
                v_actual = u_max;
                isLimitReached = true;
                // Back-calculate max achievable amperage given machine voltage limit
                amp_actual = Math.max(i_min, (u_max - 13.5 - gasKorr - matKorr - posKorr) / 0.045);
            }
            if (v_actual < u_min) {
                v_actual = u_min;
            }

            amp_actual = Math.max(i_min, Math.min(i_max, amp_actual));

            // Wire Feed Speed (WFS)
            const C = (mat1 === 'stainless' || mat2 === 'stainless') ? 135 : 150;
            const d = 0.9; // Standard 0.9mm wire
            let wfs = amp_actual / (d * d * (C / 100));

            // UI Warnings and Status Display
            const warnBox = document.getElementById('device_limit_warning');
            const warnMsg = document.getElementById('device_limit_msg');
            const statusBadge = document.getElementById('target_status_badge');

            if (isLimitReached) {
                warnBox.classList.remove('hidden');
                warnMsg.innerHTML = `Dein Projekt (${t1}mm / ${t2}mm) benötigt idealerweise <strong>${v_ideal.toFixed(1)} V</strong>. Dein Schweißgerät ist auf maximal <strong>${u_max.toFixed(1)} V</strong> begrenzt. Die Einstellungen wurden auf den Maximalwert deines Geräts angepasst.<br>💡 <strong>Empfehlung:</strong> Nahtstelle anfasen (V-Fuge) oder mehrlagig schweißen!`;
                statusBadge.className = "text-xs font-bold bg-red-100 text-red-800 px-3 py-1 rounded-full";
                statusBadge.innerText = "Gerät an Leistungsgrenze";
            } else {
                warnBox.classList.add('hidden');
                statusBadge.className = "text-xs font-bold bg-amber-100 text-amber-800 px-3 py-1 rounded-full";
                statusBadge.innerText = "Optimaler Arbeitspunkt";
            }

            // Render Values
            document.getElementById('res_v_phys').innerText = v_actual.toFixed(1) + ' V';
            document.getElementById('res_wfs_phys').innerText = wfs.toFixed(1) + ' m/min';
            document.getElementById('res_amp').innerText = Math.round(amp_actual) + ' A';

            // Knob position on 1 to 10 scale
            const uRange = u_max - u_min;
            const v_knob = uRange > 0 ? ((v_actual - u_min) / uRange) * 10 : 10;
            document.getElementById('res_v_knob').innerText = 'Regler Stufe: ' + (uRange > 0 ? v_knob.toFixed(1) : 'MAX') + ' / 10';

            if (wfs_mode === 'synergic') {
                document.getElementById('res_wfs_knob').innerText = 'Automatisch gekoppelt';
            } else {
                const wfs_per_knob = profiles[currentProfileId]?.wfs_per_knob || 1.2;
                const wfs_knob = Math.max(1, Math.min(10, wfs / wfs_per_knob));
                document.getElementById('res_wfs_knob').innerText = 'Regler Stufe: ' + wfs_knob.toFixed(1) + ' / 10';
            }

            document.getElementById('lbl_i_min').innerText = i_min;
            document.getElementById('lbl_i_max').innerText = i_max;

            const totalSpan = i_max - i_min;
            const iPercent = totalSpan > 0 ? ((amp_actual - i_min) / totalSpan) * 100 : 50;
            document.getElementById('amp_progress').style.width = Math.min(100, Math.max(5, iPercent)) + '%';
        }

        function updateGuidelines() {
            const container = document.getElementById('dynamic_guidelines');
            const safety = document.getElementById('safety_text');
            const polarHint = document.getElementById('polarization_hint');
            
            const mat1 = document.getElementById('mat1').value;
            const mat2 = document.getElementById('mat2').value;
            const gas = document.getElementById('gas').value;
            const position = document.getElementById('position').value;
            const t1 = parseFloat(document.getElementById('thickness1_num').value) || 3.0;
            const t2 = parseFloat(document.getElementById('thickness2_num').value) || t1;

            let html = '';

            // Polarization Notice
            if (gas === 'none') {
                polarHint.innerHTML = 'Selbstschützender Fülldraht erfordert <strong>DCEN (Brenner an Minuspol -)</strong>. Massezange an Pluspol (+)!';
            } else {
                polarHint.innerHTML = 'Gasgeschützter Fülldraht (FCAW-G) erfordert meist <strong>DCEP (Brenner an Pluspol +)</strong>.';
            }

            // Mixed Material Handling
            if ((mat1 === 'galvanized' || mat2 === 'galvanized') && (mat1 !== 'galvanized' || mat2 !== 'galvanized')) {
                html += `
                    <div class="p-3 bg-red-50 rounded-lg border border-red-200 text-red-900">
                        <strong class="block mb-1">⚠️ MISCHVERBINDUNG VERZINKT + BAUSTAHL:</strong>
                        Zinkschicht am verzinkten Fügepartner ca. 25-30 mm weit metallisch blank schleifen. Zinkeinschlüsse in der Schmelze führen sonst zu Poren und Sprödigkeit.
                    </div>
                `;
            } else if (mat1 === 'galvanized' && mat2 === 'galvanized') {
                html += `
                    <div class="p-3 bg-red-50 rounded-lg border border-red-200 text-red-900">
                        <strong class="block mb-1">⚠️ VERZINKTER STAHL:</strong>
                        Beidseitig Zinkschicht im Nahtbereich vollständig entfernen. Verlangsame den Vorschub um ca. 15%, um Ausgasung zu ermöglichen.
                    </div>
                `;
            }

            if ((mat1 === 'stainless' || mat2 === 'stainless') && mat1 !== mat2) {
                html += `
                    <div class="p-3 bg-purple-50 rounded-lg border border-purple-200 text-purple-900">
                        <strong class="block mb-1">✨ Schwarz-Weiß-Verbindung (Edelstahl + Baustahl):</strong>
                        Nutze für diese Mischverbindung vorzugsweise überlegierten Fülldraht (z. B. E309LT / 1.4370), um Heißrisse zu vermeiden. Verwende eine reine Edelstahl-Drahtbürste!
                    </div>
                `;
            }

            // Mixed Thickness Handling
            if (Math.abs(t1 - t2) >= 1.0) {
                html += `
                    <div class="p-3 bg-amber-50 rounded-lg border border-amber-200">
                        <strong class="text-amber-900 block mb-1">📐 UNTERSCHIEDLICHE BLECHSTÄRKEN (${t1} mm & ${t2} mm):</strong>
                        Richte den Lichtbogen zu 70% auf die dickere Seite (${Math.max(t1, t2)} mm), um dort genügend Wärme einzubringen, und ziehe das Schmelzbad kurz auf das dünnere Blech.
                    </div>
                `;
            }

            if (position === 'vertical_up') {
                html += `
                    <div class="p-3 bg-amber-100 rounded-lg border border-amber-300 text-amber-900">
                        <strong class="block mb-1">📐 Steignaht-Technik (PF):</strong>
                        Dreiecks-Pendelung. An den Seitenflanken jeweils ca. 0.5s verweilen, um Einbrandkerben aufzufüllen, und zügig über die Mitte wechseln.
                    </div>
                `;
            }

            container.innerHTML = html || `<div class="p-3 bg-amber-50 rounded-lg border border-amber-200">Standard-Vorbereitung: Nahtbereich metallisch blank schleifen und mit Aceton entfetten.</div>`;
            
            // Safety Text
            if (mat1 === 'galvanized' || mat2 === 'galvanized') {
                safety.innerText = "ACHTUNG ZINKFIEBER! Trage zwingend eine Atemmaske der Klasse FFP3 oder nutze eine Absaugung!";
            } else if (mat1 === 'stainless' || mat2 === 'stainless') {
                safety.innerText = "ACHTUNG CHROM-VI! Beim Edelstahl-Schweißen entsteht krebserregender Rauch. Effiziente Absaugung zwingend!";
            } else {
                safety.innerText = "Schweißhelm mind. DIN 10-11, Lederhandschuhe und FFP3-Atemschutzmaske tragen.";
            }
        }

        function initTorchChart() {
            const ctx = document.getElementById('torchCanvas').getContext('2d');
            torchChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    datasets: [{
                        data: [20, 80],
                        backgroundColor: ['#d97706', '#e5e7eb'],
                        borderWidth: 0,
                        circumference: 180,
                        rotation: 270
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { tooltip: { enabled: false }, legend: { display: false } },
                    cutout: '75%'
                }
            });
        }

        function updateTorchChart() {
            if (!torchChart) return;
            const position = document.getElementById('position').value;
            let angle = 20;
            let label = "Ziehend / Schleppend (15°-20°)";
            let subtext = "Schlacke immer hinter dem Schmelzbad halten!";

            if (position === 'vertical_up') {
                angle = 10;
                label = "Leicht Stechend (5°-10°)";
                subtext = "Brenner leicht nach oben richten, um Schmelze abzustützen.";
            } else if (position === 'vertical_down') {
                angle = 15;
                label = "Stechend (10°-15°)";
                subtext = "Schnelle Führung, damit Schlacke nicht überholt.";
            }

            torchChart.data.datasets[0].data = [angle, 100 - angle];
            torchChart.update();
            document.getElementById('torch_label').innerText = label;
            document.getElementById('torch_subtext').innerText = subtext;
        }

        function processSeamImage(event) {
            try {
                const file = event.target.files && event.target.files[0];
                if (!file) return;

                const loader = document.getElementById('ai_loading');
                const results = document.getElementById('ai_results');
                const previewContainer = document.getElementById('image_preview_container');
                const canvas = document.getElementById('analysis_canvas');

                results.classList.add('hidden');
                previewContainer.classList.add('hidden');
                loader.classList.remove('hidden');

                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = new Image();
                    img.onload = function() {
                        canvas.width = Math.min(600, img.width);
                        canvas.height = (img.height / img.width) * canvas.width;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

                        // Draw Simulated AI Inspection Overlay Grid
                        ctx.strokeStyle = '#22c55e';
                        ctx.lineWidth = 3;
                        ctx.strokeRect(canvas.width * 0.15, canvas.height * 0.35, canvas.width * 0.7, canvas.height * 0.3);

                        ctx.fillStyle = '#22c55e';
                        ctx.font = 'bold 12px sans-serif';
                        ctx.fillText('ISO 5817 - Zone A OK', canvas.width * 0.16, canvas.height * 0.32);

                        loader.classList.add('hidden');
                        previewContainer.classList.remove('hidden');
                        results.classList.remove('hidden');
                        results.scrollIntoView({ behavior: 'smooth' });
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            } catch(err) {
                console.error("Photo processing error", err);
                document.getElementById('ai_loading').classList.add('hidden');
                showNotice("Fehler beim Laden des Fotos. Bitte versuche es erneut.");
            }
        }

        function toggleWfsMode() {
            const selected = document.querySelector('input[name="wfs_mode"]:checked').value;
            const calBox = document.getElementById('calibration-box');
            if (selected === 'synergic') {
                calBox.classList.add('opacity-50', 'pointer-events-none');
            } else {
                calBox.classList.remove('opacity-50', 'pointer-events-none');
            }
            updateUI();
        }

        function calculateWFSConstant() {
            const lengthCm = parseFloat(document.getElementById('cal_length').value) || 150;
            const mPerMinAtKnob5 = (lengthCm / 100) * 4;
            if (profiles[currentProfileId]) {
                profiles[currentProfileId].wfs_per_knob = mPerMinAtKnob5 / 5;
                saveStorageData();
            }
            document.getElementById('v_wfs_val').innerText = mPerMinAtKnob5.toFixed(1);
            showNotice("Kalibrierung abgeschlossen!");
            updateUI();
        }

        function showSection(sectionId) {
            document.querySelectorAll('.step-section').forEach(s => s.classList.add('hidden'));
            document.getElementById(sectionId).classList.remove('hidden');
            
            document.querySelectorAll('.nav-btn').forEach(b => {
                b.classList.remove('bg-amber-600', 'text-white', 'shadow-md');
                b.classList.add('bg-white', 'text-gray-600');
            });
            
            const activeBtn = document.getElementById('nav-' + sectionId);
            if (activeBtn) {
                activeBtn.classList.remove('bg-white', 'text-gray-600');
                activeBtn.classList.add('bg-amber-600', 'text-white', 'shadow-md');
            }
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showNotice(text) {
            const notice = document.createElement('div');
            notice.className = 'fixed bottom-4 right-4 bg-amber-900 text-white text-xs px-4 py-3 rounded-xl shadow-2xl font-bold z-50 transition-all';
            notice.innerText = text;
            document.body.appendChild(notice);
            setTimeout(() => notice.remove(), 3000);
        }

        // PWA Service Worker Registration & Installation Prompt
        function initPWA() {
            if ('serviceWorker' in navigator) {
                navigator.serviceWorker.register('sw.js').then(reg => {
                    console.log('Service Worker registered successfully', reg.scope);
                }).catch(err => console.warn('SW registration failed', err));
            }

            let deferredPrompt;
            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault();
                deferredPrompt = e;
                const btn = document.getElementById('pwa-install-btn');
                btn.classList.remove('hidden');
                btn.addEventListener('click', () => {
                    btn.classList.add('hidden');
                    deferredPrompt.prompt();
                });
            });
        }
    </script>
